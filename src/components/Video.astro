---
// Video-ID aanpassen? Verander hieronder `videoId`.
const videoId = "OQj1IHfbOO4";
const thumbHd = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const thumbFallback = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---
<section class="section section--dark">
  <div class="container center">
    <span class="eyebrow">Bekijk hoe het werkt</span>
    <h2 class="section-title">OOOH! Photobooth in actie</h2>
    <p class="section-intro">Eén filmpje zegt meer dan duizend woorden — dit is de sfeer op jouw feest.</p>
    <div class="video-wrap" data-yt={videoId}>
      <button class="lyt" aria-label="Video afspelen">
        <img class="lyt__thumb" src={thumbHd} alt="" loading="lazy"
             onerror={`this.onerror=null;this.src='${thumbFallback}'`} />
        <span class="lyt__play">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg>
        </span>
      </button>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".video-wrap[data-yt]").forEach((wrap) => {
    const btn = wrap.querySelector(".lyt");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const id = wrap.getAttribute("data-yt");
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = "Lens Event photobooth video";
      iframe.allow =
        "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
      iframe.allowFullscreen = true;
      iframe.setAttribute("referrerpolicy", "strict-origin-when-cross-origin");
      wrap.innerHTML = "";
      wrap.appendChild(iframe);
    });
  });
</script>

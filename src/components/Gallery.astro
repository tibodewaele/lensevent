// Sfeerbeelden — pas de bestanden aan in /public/images
---
<section class="section section--paper">
  <div class="container center">
    <span class="eyebrow">Sfeerbeeld</span>
    <h2 class="section-title">Lachen gegarandeerd</h2>
    <p class="section-intro">Onze stijlvolle booth maakt van elk feest een feest om nooit te vergeten.</p>
    <div class="gallery">
      <img class="tall" src="/images/ooh-man-3.png" alt="Lachende man met feestattributen" loading="lazy" />
      <img src="/images/ooh-woman.png" alt="Lachende vrouw met feestattributen" loading="lazy" />
      <img src="/images/booth-tall.png" alt="Stijlvolle houten photobooth met ringlamp" loading="lazy" />
      <img src="/images/print-2x6.png" alt="Voorbeeld van een fotostrip" loading="lazy" />
      <img src="/images/ooh-man-1.png" alt="Gast met feestbril en kroon" loading="lazy" />
      <img src="/images/ooh-man-2.png" alt="Verraste gast bij de photobooth" loading="lazy" />
      <img src="/images/booth-1.png" alt="De Lens Event photobooth in actie" loading="lazy" />
    </div>
  </div>
</section>

---
export const prerender = false;
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin — Lens Event</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0; padding: 40px 16px;
      background: #f7f1e8;
      font-family: Inter, system-ui, sans-serif;
      color: #1c1714;
      display: flex; align-items: flex-start; justify-content: center;
      min-height: 100vh;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      padding: 40px 36px;
      max-width: 520px;
      width: 100%;
      box-shadow: 0 10px 40px rgba(20,12,6,.12);
    }
    .logo {
      font-family: Poppins, sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: #15110f;
      margin: 0 0 4px;
    }
    .logo span { color: #d8a24a; }
    .subtitle {
      font-size: 12px;
      color: #b9842f;
      letter-spacing: .2em;
      text-transform: uppercase;
      margin: 0 0 28px;
    }
    h1 {
      font-family: Poppins, sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: #15110f;
      margin: 0 0 24px;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #7a6f64;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid #e7ddcd;
      border-radius: 8px;
      font-size: 15px;
      font-family: inherit;
      color: #15110f;
      background: #fff;
      margin-bottom: 16px;
      outline: none;
      transition: border-color .2s;
    }
    input:focus { border-color: #d8a24a; }
    button {
      width: 100%;
      background: #15110f;
      color: #f7f1e8;
      border: none;
      border-radius: 999px;
      padding: 14px;
      font-family: Poppins, sans-serif;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      transition: opacity .2s;
    }
    button:disabled { opacity: .6; cursor: not-allowed; }
    .status {
      margin-top: 16px;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 14px;
      display: none;
    }
    .status.ok { display: block; background: #d9ead3; color: #274e13; }
    .status.err { display: block; background: #f4cccc; color: #660000; }
    .divider {
      border: none;
      border-top: 1.5px solid #e7ddcd;
      margin: 36px 0;
    }
  </style>
</head>
<body>
  <div class="card">
    <p class="logo">Lens <span>Event</span></p>
    <p class="subtitle">Admin</p>
    <h1>Template koppelen aan boeking</h1>

    <form id="form">
      <label for="email">E-mailadres klant</label>
      <input id="email" name="email" type="email" required placeholder="klant@email.be" />

      <label for="datum">Datum van het feest</label>
      <input id="datum" name="datum" type="date" required />

      <label for="templateUrl">Template-link (uit de mail van templatesbooth)</label>
      <input id="templateUrl" name="templateUrl" type="url" required placeholder="https://…" />

      <label for="secret">Wachtwoord</label>
      <input id="secret" name="secret" type="password" required placeholder="••••••••" />

      <button type="submit">Opslaan in sheet</button>
    </form>
    <div class="status" id="status"></div>

    <hr class="divider" />

    <h1>Nafeest-mail sturen</h1>
    <p style="margin:0 0 20px;font-size:14px;color:#7a6f64;line-height:1.6;">
      Vul de fotolink in. De mail wordt automatisch ingepland op 1 dag na het feest (of direct als die datum al voorbij is).
    </p>

    <form id="form2">
      <label for="naam2">Volledige naam klant</label>
      <input id="naam2" name="naam" required placeholder="Bv. Marie Janssen" />

      <label for="email2">E-mailadres klant</label>
      <input id="email2" name="email" type="email" required placeholder="klant@email.be" />

      <label for="datum2">Datum van het feest</label>
      <input id="datum2" name="datum" type="date" required />

      <label for="fotolink">Link naar de foto's</label>
      <input id="fotolink" name="fotolink" type="url" required placeholder="https://…" />

      <label for="secret2">Wachtwoord</label>
      <input id="secret2" name="secret" type="password" required placeholder="••••••••" />

      <button type="submit" id="btn2">Verstuur nafeest-mail</button>
    </form>
    <div class="status" id="status2"></div>
  </div>

  <script>
    const form = document.getElementById('form');
    const statusEl = document.getElementById('status');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.className = 'status';
      const btn = form.querySelector('button');
      btn.disabled = true;
      btn.textContent = 'Opslaan…';

      try {
        const res = await fetch('/api/update-template', {
          method: 'POST',
          body: new FormData(form),
        });
        const json = await res.json();
        if (json.ok) {
          statusEl.textContent = 'Template succesvol opgeslagen in Google Sheet!';
          statusEl.className = 'status ok';
          form.reset();
        } else {
          statusEl.textContent = json.error || 'Er ging iets mis.';
          statusEl.className = 'status err';
        }
      } catch {
        statusEl.textContent = 'Netwerkfout. Probeer opnieuw.';
        statusEl.className = 'status err';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Opslaan in sheet';
      }
    });

    const form2 = document.getElementById('form2');
    const status2El = document.getElementById('status2');
    const btn2 = document.getElementById('btn2');

    form2.addEventListener('submit', async (e) => {
      e.preventDefault();
      status2El.className = 'status';
      btn2.disabled = true;
      btn2.textContent = 'Versturen…';

      try {
        const res = await fetch('/api/send-afterevent', {
          method: 'POST',
          body: new FormData(form2),
        });
        const json = await res.json();
        if (json.ok) {
          const msg = json.scheduled
            ? `Mail ingepland voor ${new Date(json.sendAt).toLocaleDateString('nl-BE', { day: 'numeric', month: 'long', year: 'numeric' })} om 10:00.`
            : 'Mail is direct verstuurd (feest was al voorbij).';
          status2El.textContent = msg;
          status2El.className = 'status ok';
          form2.reset();
        } else {
          status2El.textContent = json.error || 'Er ging iets mis.';
          status2El.className = 'status err';
        }
      } catch {
        status2El.textContent = 'Netwerkfout. Probeer opnieuw.';
        status2El.className = 'status err';
      } finally {
        btn2.disabled = false;
        btn2.textContent = 'Verstuur nafeest-mail';
      }
    });
  </script>
</body>
</html>
